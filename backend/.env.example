# ==================================================
# LexIndia Environment Variables
# Copy this file to .env and fill in your values
# ==================================================

# Database (async — used by FastAPI + SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://lexuser:lexpass@postgres:5432/lexindia

# Database (sync — used by Alembic migrations)
DATABASE_URL_SYNC=postgresql://lexuser:lexpass@postgres:5432/lexindia

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI — used for GPT-4o (text generation, Call 1 only)
OPENAI_API_KEY=your_openai_api_key_here

# App
SECRET_KEY=your_random_secret_key_here
ALLOWED_ORIGINS=http://localhost:3000,https://lexindia.vercel.app
ENVIRONMENT=development
LOG_LEVEL=INFO

# Embedding model (runs locally, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# RAG pipeline
SIMILARITY_THRESHOLD=0.50
MAX_RESULTS=8
CACHE_TTL_SECONDS=86400
